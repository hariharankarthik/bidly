# Copy to .env.local and fill with your Supabase project (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use either the legacy anon JWT or the new publishable key (not both required).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: host “Fetch CricAPI & score” on Fantasy league (server-side only; add in Vercel Production).
CRICAPI_KEY=
