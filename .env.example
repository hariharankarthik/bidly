# Copy to .env.local and fill with your Supabase project (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use either the legacy anon JWT or the new publishable key (not both required).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: host “Fetch CricAPI & score” on Fantasy league (server-side only; add in Vercel Production).
CRICAPI_KEY=

# Vercel Cron (optional): server-side sync for active fantasy leagues.
# Comma-separated CricAPI match UUIDs; leave empty to auto-discover from currentMatches.
CRON_SECRET=
CRICAPI_DAILY_MATCH_IDS=
# YYYY-MM-DD: anchor day for discovery (primary + “yesterday” fallback is relative to this day) and fantasy_scores.match_date.
# Leave empty to use today (UTC).
CRICAPI_DAILY_MATCH_DATE=
# CricAPI series_id for IPL (from currentMatches); discovery matches this id only for series scoping.
CRICAPI_IPL_SERIES_ID=
# Optional extra gate on team short / full names in currentMatches.
CRICAPI_IPL_TEAM_SUBSTRINGS=
